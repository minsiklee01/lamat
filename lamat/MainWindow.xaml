<Window x:Class="lamat.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:lamat.Controls"
        mc:Ignorable="d"
        Title="Jarai Typing Trainer" Height="760" Width="860"
        Background="{StaticResource BgBrush}"
        PreviewKeyDown="Window_KeyDown"
        PreviewKeyUp="Window_KeyUp"
        PreviewTextInput="Window_TextInput">
    <Grid>

        <!-- ══════════════════════ Home Screen ══════════════════════ -->
        <Grid x:Name="HomePanel">
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="20"
                    Padding="56,52"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="380">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.35"
                                      BlurRadius="32" ShadowDepth="0"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Jarai Keyboard Trainer"
                               FontFamily="Segoe UI"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="Choose a mode to start practising"
                               FontFamily="Segoe UI"
                               FontSize="13"
                               Foreground="{StaticResource MutedBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,36"/>
                    <Button Content="Word Practice"
                            Height="52"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Margin="0,0,0,12"
                            Click="WordPracticeBtn_Click"/>
                    <Button Content="Sentence Practice"
                            Height="52"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Click="SentencePracticeBtn_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══════════════════════ Practice Shell ══════════════════════ -->
        <Grid x:Name="PracticePanel" Visibility="Collapsed">
            <StackPanel Margin="48,32,48,32">

                <!-- Top bar -->
                <Grid Margin="0,0,0,28">
                    <Button Content="← Home"
                            Style="{StaticResource GhostButton}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Click="HomeBtn_Click"/>
                    <TextBlock x:Name="ProgressText"
                               FontFamily="Segoe UI"
                               FontSize="13"
                               Foreground="{StaticResource MutedBrush}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- Target word -->
                <TextBlock x:Name="TargetText"
                           FontFamily="Segoe UI"
                           FontSize="38"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,36"/>

                <!-- ── Word practice section ── -->
                <StackPanel x:Name="KeySequencePanel">

                    <!-- Expected key badge -->
                    <TextBlock Text="PRESS"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{StaticResource MutedBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>
                    <Border Background="{StaticResource Surface2Brush}"
                            BorderBrush="{StaticResource AccentBrush}"
                            BorderThickness="2"
                            CornerRadius="12"
                            Padding="32,14"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,28">
                        <TextBlock x:Name="ExpectedKeyText"
                                   FontFamily="Segoe UI"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center"/>
                    </Border>

                    <!-- Your input -->
                    <TextBlock Text="YOUR INPUT"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{StaticResource MutedBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock x:Name="ActualKeyText"
                               FontFamily="Segoe UI"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="{StaticResource MutedBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,4"/>

                    <!-- Visual keyboard -->
                    <controls:JaraiKeyboardControl x:Name="JaraiKeyboard"
                                                   Margin="0,20,0,0"
                                                   HorizontalAlignment="Center"/>

                </StackPanel>

                <!-- ── Sentence practice section ── -->
                <StackPanel x:Name="SentencePanel" Visibility="Collapsed">
                    <TextBlock Text="Type the highlighted word and press Space to advance"
                               FontFamily="Segoe UI"
                               FontSize="13"
                               Foreground="{StaticResource MutedBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>
                    <TextBox x:Name="SentenceInput"
                             FontSize="20"
                             Height="52"
                             KeyDown="SentenceInput_KeyDown"/>
                </StackPanel>

                <!-- Status / feedback -->
                <TextBlock x:Name="StatusText"
                           FontFamily="Segoe UI"
                           FontSize="14"
                           Foreground="{StaticResource MutedBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0"/>

            </StackPanel>
        </Grid>

    </Grid>
</Window>

<Window x:Class="lamat.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:lamat"
        mc:Ignorable="d"
        Title="Jarai Typing Trainer" Height="500" Width="800"
        PreviewKeyDown="Window_KeyDown"
        PreviewKeyUp="Window_KeyUp"
        PreviewTextInput="Window_TextInput">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock
                Text="Jarai Keyboard Trainer"
                FontSize="24"
                Margin="0,0,0,16"
            />

            <!-- Mode selector -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Button x:Name="WordPracticeBtn" Content="Word Practice" Width="110" Margin="0,0,8,0" Click="WordPracticeBtn_Click"/>
                <Button x:Name="SentencePracticeBtn" Content="Sentence Practice" Width="130" Click="SentencePracticeBtn_Click"/>
            </StackPanel>

            <TextBlock
                x:Name="ProgressText"
                FontSize="14"
                Margin="0,0,0,12"
            />

            <TextBlock
                x:Name="TargetText"
                FontSize="20"
                Margin="0,0,0,12"
            />

            <!-- Key/Word practice section -->
            <StackPanel x:Name="KeySequencePanel">
                <TextBlock
                    Text="Expected Key:"
                    FontSize="14"
                    Margin="0,0,0,6"
                />
                <TextBlock
                    x:Name="ExpectedKeyText"
                    FontSize="24"
                    FontWeight="Bold"
                    Margin="0,0,0,6"
                />
                <TextBlock
                    Text="Your Input:"
                    FontSize="14"
                    Margin="0,0,0,6"
                />
                <TextBlock
                    x:Name="ActualKeyText"
                    FontSize="24"
                    FontWeight="Bold"
                    Foreground="Gray"
                    Margin="0,0,0,12"
                />
                <Border
                    BorderBrush="Gray"
                    BorderThickness="1"
                    Height="80"
                    Margin="0,0,0,12"
                >
                    <TextBlock
                        x:Name="KeyboardHintText"
                        FontSize="22"
                        FontWeight="Bold"
                        Foreground="Red"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                    />
                </Border>
            </StackPanel>

            <!-- Sentence practice section -->
            <StackPanel x:Name="SentencePanel" Visibility="Collapsed">
                <TextBlock
                    Text="Type the highlighted word, press Space to advance:"
                    FontSize="14"
                    Margin="0,0,0,6"
                />
                <TextBox
                    x:Name="SentenceInput"
                    FontSize="20"
                    Height="40"
                    Margin="0,0,0,12"
                    KeyDown="SentenceInput_KeyDown"
                />
            </StackPanel>

            <TextBlock
                x:Name="StatusText"
                FontSize="14"
                Margin="0,8,0,0"
            />
        </StackPanel>
    </Grid>
</Window>
